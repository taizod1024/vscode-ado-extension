{
  "version": "0.0.3",
  "name": "ado-ext",
  "displayName": "Azure DevOps Extension",
  "description": "A VS Code extension for Azure DevOps",
  "engines": {
    "vscode": "^1.117.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "Azure DevOps"
  ],
  "publisher": "taizod1024",
  "main": "./build/main.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ado-ext.refreshIterationItems",
        "title": "Azure DevOps: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ado-ext.refreshPrItems",
        "title": "Azure DevOps: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ado-ext.openUrl",
        "title": "Azure DevOps: Open URL",
        "icon": "$(globe)"
      },
      {
        "command": "ado-ext.openCreatePullRequest",
        "title": "Azure DevOps: Create Pull Request",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "ado-ext.openSprints",
        "title": "Azure DevOps: Sprints",
        "icon": "$(calendar)"
      },
      {
        "command": "ado-ext.openSprintSettings",
        "title": "Azure DevOps: Sprint Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "ado-ext.openWorkItems",
        "title": "Azure DevOps: Work Items",
        "icon": "$(checklist)"
      },
      {
        "command": "ado-ext.cloneRepo",
        "title": "Azure DevOps: Clone Repository",
        "icon": "$(repo-clone)"
      },
      {
        "command": "ado-ext.openGitGraph",
        "title": "Azure DevOps: Open Git Graph",
        "icon": "$(git-commit)"
      },
      {
        "command": "ado-ext.setWorkItemTodo",
        "title": "To do",
        "icon": "$(issues)"
      },
      {
        "command": "ado-ext.setWorkItemDoing",
        "title": "Doing",
        "icon": "$(run)"
      },
      {
        "command": "ado-ext.setWorkItemDone",
        "title": "Done",
        "icon": "$(check)"
      },
      {
        "command": "ado-ext.assignWorkItemToMe",
        "title": "Assign to me",
        "icon": "$(person-add)"
      },
      {
        "command": "ado-ext.addOrganization",
        "title": "Azure DevOps: Add Organization",
        "icon": "$(add)"
      },
      {
        "command": "ado-ext.removeOrganization",
        "title": "Azure DevOps: Remove Organization",
        "icon": "$(remove)"
      },
      {
        "command": "ado-ext.removeAllOrganizations",
        "title": "Azure DevOps: Remove All Organizations",
        "icon": "$(trash)"
      },
      {
        "command": "ado-ext.refreshNode",
        "title": "Azure DevOps: Refresh Node",
        "icon": "$(refresh)"
      },
      {
        "command": "ado-ext.sendWorkItemToCopilot",
        "title": "Azure DevOps: Send Work Item to GitHub Copilot",
        "icon": "$(copilot)"
      },
      {
        "command": "ado-ext.createBranchForWorkItem",
        "title": "Azure DevOps: Create Branch for Work Item",
        "icon": "$(git-branch)"
      },
      {
        "command": "ado-ext.openSettings",
        "title": "Azure DevOps: Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "ado-ext.setIterationItemFilter.all",
        "title": "All"
      },
      {
        "command": "ado-ext.setIterationItemFilter.assigned",
        "title": "Assigned to me"
      },
      {
        "command": "ado-ext.setIterationItemFilter.myactivity",
        "title": "My activity"
      },
      {
        "command": "ado-ext.setIterationItemFilter.active",
        "title": "Active"
      },
      {
        "command": "ado-ext.setPrFilter.mine",
        "title": "Mine"
      },
      {
        "command": "ado-ext.setPrFilter.active",
        "title": "Active"
      },
      {
        "command": "ado-ext.setPrFilter.completed",
        "title": "Completed"
      },
      {
        "command": "ado-ext.setPrFilter.abandoned",
        "title": "Abandoned"
      }
    ],
    "menus": {
      "commandPalette": [],
      "view/title": [
        {
          "command": "ado-ext.addOrganization",
          "when": "view == azureDevOps.sidePanel",
          "group": "navigation@1"
        },
        {
          "command": "ado-ext.removeAllOrganizations",
          "when": "view == azureDevOps.sidePanel",
          "group": "navigation@2"
        },
        {
          "command": "ado-ext.openSettings",
          "when": "view == azureDevOps.sidePanel",
          "group": "navigation@99"
        }
      ],
      "view/item/context": [
        {
          "command": "ado-ext.refreshNode",
          "when": "view == azureDevOps.sidePanel && viewItem == organization",
          "group": "inline"
        },
        {
          "command": "ado-ext.openUrl",
          "when": "view == azureDevOps.sidePanel && viewItem == organization",
          "group": "inline@99"
        },
        {
          "command": "ado-ext.removeOrganization",
          "when": "view == azureDevOps.sidePanel && viewItem == organization",
          "group": "inline"
        },
        {
          "command": "ado-ext.openUrl",
          "when": "view == azureDevOps.sidePanel && viewItem == adoProject",
          "group": "inline@99"
        },
        {
          "command": "ado-ext.openSprints",
          "when": "view == azureDevOps.sidePanel && viewItem == sprintsFolder",
          "group": "inline"
        },
        {
          "command": "ado-ext.openSprintSettings",
          "when": "view == azureDevOps.sidePanel && viewItem == sprintsFolder",
          "group": "inline@99"
        },
        {
          "command": "ado-ext.openWorkItems",
          "when": "view == azureDevOps.sidePanel && viewItem == sprintsFolder",
          "group": "inline@98"
        },
        {
          "command": "ado-ext.openUrl",
          "when": "view == azureDevOps.sidePanel && viewItem == repositoriesFolder",
          "group": "inline@99"
        },
        {
          "command": "ado-ext.openUrl",
          "when": "view == azureDevOps.sidePanel && viewItem == repo",
          "group": "inline@99"
        },
        {
          "command": "ado-ext.cloneRepo",
          "when": "view == azureDevOps.sidePanel && viewItem == repo",
          "group": "inline"
        },
        {
          "command": "ado-ext.openGitGraph",
          "when": "view == azureDevOps.sidePanel && viewItem == repo",
          "group": "inline"
        },
        {
          "command": "ado-ext.openUrl",
          "when": "view == azureDevOps.sidePanel && viewItem == board",
          "group": "inline@99"
        },
        {
          "command": "ado-ext.openUrl",
          "when": "view == azureDevOps.sidePanel && (viewItem == workitem_todo || viewItem == workitem_doing || viewItem == workitem_done)",
          "group": "inline@99"
        },
        {
          "command": "ado-ext.sendWorkItemToCopilot",
          "when": "view == azureDevOps.sidePanel && (viewItem == workitem_todo || viewItem == workitem_doing)",
          "group": "inline@2"
        },
        {
          "command": "ado-ext.createBranchForWorkItem",
          "when": "view == azureDevOps.sidePanel && (viewItem == workitem_todo || viewItem == workitem_doing)",
          "group": "inline@1"
        },
        {
          "command": "ado-ext.setWorkItemTodo",
          "when": "view == azureDevOps.sidePanel && (viewItem == workitem_todo || viewItem == workitem_doing || viewItem == workitem_done)",
          "group": "workitem@1"
        },
        {
          "command": "ado-ext.setWorkItemDoing",
          "when": "view == azureDevOps.sidePanel && (viewItem == workitem_todo || viewItem == workitem_doing || viewItem == workitem_done)",
          "group": "workitem@2"
        },
        {
          "command": "ado-ext.setWorkItemDone",
          "when": "view == azureDevOps.sidePanel && (viewItem == workitem_todo || viewItem == workitem_doing || viewItem == workitem_done)",
          "group": "workitem@3"
        },
        {
          "command": "ado-ext.assignWorkItemToMe",
          "when": "view == azureDevOps.sidePanel && (viewItem == workitem_todo || viewItem == workitem_doing || viewItem == workitem_done)",
          "group": "workitem_assign@1"
        },
        {
          "command": "ado-ext.openUrl",
          "when": "view == azureDevOps.sidePanel && viewItem == pullrequest",
          "group": "inline@99"
        },
        {
          "command": "ado-ext.openUrl",
          "when": "view == azureDevOps.sidePanel && viewItem == pullRequestsFolder",
          "group": "inline@99"
        },
        {
          "command": "ado-ext.openUrl",
          "when": "view == azureDevOps.sidePanel && viewItem == sprintsIteration",
          "group": "inline@99"
        },
        {
          "command": "ado-ext.openCreatePullRequest",
          "when": "view == azureDevOps.sidePanel && viewItem == branch",
          "group": "inline"
        },
        {
          "command": "ado-ext.openUrl",
          "when": "view == azureDevOps.sidePanel && viewItem == branch",
          "group": "inline@99"
        },
        {
          "command": "ado-ext.refreshIterationItems",
          "when": "view == azureDevOps.sidePanel && viewItem =~ /^sprintsIterationFilter_/",
          "group": "inline"
        },
        {
          "command": "ado-ext.setIterationItemFilter.all",
          "when": "view == azureDevOps.sidePanel && viewItem =~ /^sprintsIterationFilter_/",
          "group": "1_filter@1"
        },
        {
          "command": "ado-ext.setIterationItemFilter.assigned",
          "when": "view == azureDevOps.sidePanel && viewItem =~ /^sprintsIterationFilter_/",
          "group": "1_filter@2"
        },
        {
          "command": "ado-ext.setIterationItemFilter.myactivity",
          "when": "view == azureDevOps.sidePanel && viewItem =~ /^sprintsIterationFilter_/",
          "group": "1_filter@3"
        },
        {
          "command": "ado-ext.setIterationItemFilter.active",
          "when": "view == azureDevOps.sidePanel && viewItem =~ /^sprintsIterationFilter_/",
          "group": "1_filter@4"
        },
        {
          "command": "ado-ext.refreshPrItems",
          "when": "view == azureDevOps.sidePanel && viewItem =~ /^pullRequestsFilter_/",
          "group": "inline"
        },
        {
          "command": "ado-ext.setPrFilter.mine",
          "when": "view == azureDevOps.sidePanel && viewItem =~ /^pullRequestsFilter_/",
          "group": "1_filter@1"
        },
        {
          "command": "ado-ext.setPrFilter.active",
          "when": "view == azureDevOps.sidePanel && viewItem =~ /^pullRequestsFilter_/",
          "group": "1_filter@2"
        },
        {
          "command": "ado-ext.setPrFilter.completed",
          "when": "view == azureDevOps.sidePanel && viewItem =~ /^pullRequestsFilter_/",
          "group": "1_filter@3"
        },
        {
          "command": "ado-ext.setPrFilter.abandoned",
          "when": "view == azureDevOps.sidePanel && viewItem =~ /^pullRequestsFilter_/",
          "group": "1_filter@4"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "azureDevOps",
          "title": "Azure DevOps Extension",
          "icon": "$(azure-devops)"
        }
      ]
    },
    "views": {
      "azureDevOps": [
        {
          "id": "azureDevOps.sidePanel",
          "name": "Azure DevOps Extension",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "keybindings": [],
    "configuration": {
      "title": "Azure DevOps Extension",
      "properties": {
        "adoExt.branchPrefix": {
          "type": "string",
          "default": "working",
          "description": "Prefix for created branches (e.g., working/username/#id_title)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=build/main.js --format=cjs --platform=node --external:vscode",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "test": "node ./build/test/runTest.js",
    "vscode:uninstall": "node bin/uninstall.js",
    "release": "npm run release-premerge && npx standard-version && vsce publish && npm run release-postmerge",
    "release-premerge": "git switch main && git merge --no-ff develop --no-edit",
    "release-postmerge": "git push --follow-tags origin main && git push origin develop && git switch develop",
    "package": "vsce package",
    "clean": "rmdir /q /s .\\build || exit /b 0"
  },
  "author": "yamamoto.taizo <taizod1024@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^13.2.0",
    "@types/mocha": "^9.0.0",
    "@types/superagent": "^4.1.13",
    "@types/superagent-proxy": "^2.0.1",
    "@types/vscode": "^1.116.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.0.1",
    "husky": "^9.1.7",
    "standard-version": "^9.5.0",
    "ts-node": "^10.3.0",
    "typescript": "^4.4.4",
    "utf-8-validate": "^5.0.7",
    "@types/node": "^20.5.6",
    "vscode-test": "^1.4.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/taizod1024/vscode-ado-extension.git"
  }
}
